# Copy this file to .env and set SECRET_KEY for production
SECRET_KEY=change-me-to-a-strong-secret
ADMIN_PASS=change-me-to-a-strong-password

# Optional one-time token for token-login (keep secret)
ADMIN_TOKEN=

# Optional global student token required for short /student/<id> links
STUDENT_TOKEN=

# If running behind trusted reverse proxies, list their IPs comma-separated
# so the app can honor X-Forwarded-For when determining the real client IP.
# Example: 127.0.0.1,::1
TRUSTED_PROXIES=
